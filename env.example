TLSENTINEL_HOST=127.0.0.1
TLSENTINEL_PORT=8080

TLSENTINEL_DB_HOST=localhost
TLSENTINEL_DB_PORT=5432
TLSENTINEL_DB_NAME=tlsentinel
TLSENTINEL_DB_USERNAME=tlsentinel
TLSENTINEL_DB_PASSWORD=changeme
TLSENTINEL_DB_SSLMODE=disable

# JWT signing secret — base64-encoded, must decode to >=32 bytes
# Generate: openssl rand -base64 32
TLSENTINEL_JWT_SECRET=

# AES-256 key for encrypting SMTP passwords at rest (optional but recommended)
# Generate: openssl rand -base64 32
TLSENTINEL_ENCRYPTION_KEY=

# Bootstrap admin account
TLSENTINEL_ADMIN_USERNAME=admin
TLSENTINEL_ADMIN_PASSWORD=changeme

# OIDC configuration, optional
#TLSENTINEL_OIDC_ISSUER=
#TLSENTINEL_OIDC_CLIENT_ID=
#TLSENTINEL_OIDC_CLIENT_SECRET=
#TLSENTINEL_OIDC_REDIRECT_URL=

# Comma-separated CIDRs whose traffic is allowed to set X-Forwarded-For.
# Requests NOT coming from a trusted CIDR have XFF ignored — the audit log
# records the TCP peer IP instead. Empty means no proxies are trusted.
#
# Typical deployments:
#   Traefik / nginx sidecar on same host:     127.0.0.1/32,::1/128
#   Proxy on docker-compose default bridge:   172.16.0.0/12
#   Kubernetes (any internal pod):            10.0.0.0/8,192.168.0.0/16
#TLSENTINEL_TRUSTED_PROXY_CIDRS=